# Copier vers .env à la racine du projet : cp .env.example .env
#
# --- Créer la base (une fois MySQL démarré) ---
#   mysql -u root -p -e "CREATE DATABASE aesculia_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
#
# --- Erreur Django (2003) / macOS (61) = connexion refusée ---
#   → MySQL n’écoute pas sur l’hôte/port indiqués (service arrêté ou mauvais port).
#   Homebrew : brew services start mysql   puis   lsof -nP -iTCP:3306 | grep LISTEN
#   MAMP : souvent DB_PORT=8889 (vérifier dans MAMP).
#   Docker : DB_HOST=127.0.0.1 et le port mappé (ex. DB_PORT=3307).
#
# --- Connexion par socket (souvent utile sur Mac avec MySQL local) ---
#   Django : DB_SOCKET doit être un chemin absolu ; il est mappé sur HOST (requis par le backend MySQL).
#   Vérifier : ls -l /tmp/mysql.sock   ou   lsof /tmp/mysql.sock
#   Apple Silicon (données Homebrew) : parfois /opt/homebrew/var/mysql/mysql.sock

DB_NAME=aesculia_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

DB_SOCKET=/tmp/mysql.sock

# Optionnel : mysqlclient (C) au lieu de PyMySQL → pip install mysqlclient
