# Copier vers .env à la racine de PROJET_PYTHON :
#   copy .env.example .env
#
# --- Créer la base (une fois MySQL démarré) ---
#   python scripts/create_mysql_db.py
#   ou : mysql -u root -p -e "CREATE DATABASE aesculia_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
#
# --- Windows ---
#   Ne pas définir DB_SOCKET (connexion TCP avec DB_HOST / DB_PORT).
#   XAMPP / WAMP : adapter DB_PORT si besoin (souvent 3306).
#
# --- Erreur Django (2003) = connexion refusée ---
#   → MySQL arrêté ou mauvais port. Services Windows : démarrer MySQL.
#
# --- Connexion par socket (souvent Mac / Linux) ---
#   DB_SOCKET doit être un chemin absolu (Django le mappe sur HOST).
#   Exemple Mac (Homebrew) : DB_SOCKET=/tmp/mysql.sock
#   Laisser DB_SOCKET vide ou supprimer la ligne pour utiliser TCP.

DB_NAME=aesculia_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Optionnel (Mac/Linux, chemin absolu). Sous Windows : ne pas définir.
# DB_SOCKET=

# Optionnel : mysqlclient (C) au lieu de PyMySQL → pip install mysqlclient
